# ELI v2.0 — full environment reference.
#
# Every variable here is OPTIONAL. Most installs need none of them: ELI resolves
# its project root, data directories, and model paths automatically on Windows,
# macOS, Linux, BSD, and Android. Copy this file to `.env` and uncomment only
# what you want to override. For the short version, see `.env.example`.

# ── Core paths ────────────────────────────────────────────────────────────────
# Project root override. Leave unset for normal installs (auto-detected).
# ELI_PROJECT_ROOT=/absolute/path/to/ELI_v2.0

# Where runtime data (databases, logs, generated files) lives. Default: artifacts/.
# ELI_ARTIFACTS_DIR=artifacts

# Where local models live. Default: models/ (scanned recursively).
# ELI_MODELS_DIR=models

# Where ELI writes generated documents. Default: artifacts/documents.
# ELI_DOC_DIR=artifacts/documents

# ── Model & inference ─────────────────────────────────────────────────────────
# Inference provider. custom_gguf (default, local llama-cpp) or ollama.
ELI_PROVIDER=custom_gguf

# Explicit chat model path (otherwise picked in Settings / first-run wizard).
# Relative paths resolve from ELI_PROJECT_ROOT.
# ELI_GGUF_MODEL_PATH=models/gguf/base/model.gguf

# Context window, GPU layers, batch, threads. "auto" sizes to your hardware
# (reads the model's real n_ctx_train and your VRAM/RAM).
ELI_GGUF_N_CTX=16384
ELI_GGUF_N_GPU_LAYERS=auto
ELI_GGUF_N_BATCH=512
ELI_GGUF_THREADS=auto

# Force CPU inference even when a GPU is present.
# ELI_FORCE_CPU=1

# VRAM headroom (MiB) kept free when auto-fitting layers/context.
# ELI_VRAM_RESERVE_MB=512

# Ollama backend (only when ELI_PROVIDER=ollama).
# ELI_OLLAMA_HOST=http://127.0.0.1:11434

# Image generation model directory (optional SSD-1B diffusion).
# ELI_IMAGE_MODEL_PATH=models/image/ssd-1b

# ── Voice ─────────────────────────────────────────────────────────────────────
# Wake word: 0 = wake word required for free-form speech (default), 1 = disable
# wake-word listening entirely.
ELI_DISABLE_WAKE_WORD=0

# Allow free-form speech WITHOUT the wake word (not recommended with TV/music).
ELI_STT_ALLOW_DIRECT_CHAT=0
ELI_STT_MIN_DIRECT_CHAT_WORDS=4

# Microphone selection + sensitivity (see: .venv/bin/python -m eli.tools.mic_diag).
# ELI_MIC_DEVICE_INDEX=0
# ELI_STT_ENERGY_THRESHOLD=300

# Piper TTS voice basename (default: en_US-amy-medium).
# ELI_TTS_VOICE=en_US-amy-medium

# Keep speech-to-text strictly local (never fetch missing Whisper weights).
# ELI_WHISPER_LOCAL_ONLY=1

# ── Web / API server (scripts/eli_serve.sh) ───────────────────────────────────
# Bind host & port. eli_serve.sh manages these; set them only for manual launches.
# ELI_API_HOST=127.0.0.1
# ELI_API_PORT=8081

# Bearer token for the LAN web app. With --lan and no token set, one is
# auto-generated and printed — never served unauthenticated.
# ELI_API_TOKEN=change-me

# Require a token even on loopback (default allows tokenless loopback only).
# ELI_API_ALLOW_TOKENLESS=0

# Multi-user / hardened hosts: require a bearer token for localhost too
# (default 1 keeps the local operator as admin so you can't lock yourself out).
# ELI_LOOPBACK_ADMIN=0

# ── Security & execution ──────────────────────────────────────────────────────
# Allowlist for the strict _run() helper (comma-separated executable names).
# Unset = that path stays fail-closed. See SECURITY.md for the three shell paths.
# ELI_ALLOWED_CMDS=playerctl,wmctrl,xdotool

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Proactive daemon (morning briefing, habit suggestions). 1 = on (default).
ELI_PROACTIVE=1

# Log level (DEBUG / INFO / WARNING / ERROR).
# ELI_LOG_LEVEL=INFO

# GitHub release tag used for asset restore (models/voices).
# ELI_ASSET_RELEASE_TAG=local-assets-v2.1
