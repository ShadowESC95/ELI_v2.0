# ELI MKXI minimal environment example.
# Most installs do not need this file. ELI resolves the project root and
# user data directories dynamically on Windows, macOS, Linux, BSD, and Android.
#
# For every supported variable, use .env.full.example.

ELI_PROVIDER=custom_gguf

# Optional project root override. Leave unset for normal installs.
# ELI_PROJECT_ROOT=/absolute/path/to/ELI_MKXI

# Optional model overrides. Relative paths are resolved from ELI_PROJECT_ROOT.
# ELI_MODELS_DIR=models
# ELI_GGUF_MODEL_PATH=models/gguf/base/model.gguf
# ELI_IMAGE_MODEL_PATH=models/image/ssd-1b

ELI_GGUF_N_CTX=16384
ELI_GGUF_N_GPU_LAYERS=auto
ELI_GGUF_N_BATCH=512
ELI_GGUF_THREADS=auto
ELI_PROACTIVE=1

# Voice input. Free-form speech now requires the wake word by default so TV,
# speakers, and room noise do not get treated as chat. Safe media commands
# such as pause/resume/volume can still work without the wake word.
ELI_DISABLE_WAKE_WORD=0
ELI_STT_ALLOW_DIRECT_CHAT=0
ELI_STT_MIN_DIRECT_CHAT_WORDS=4
