# Coverage configuration — combined across the three test lanes.
# Full, honest coverage is measured across THREE lanes and combined:
#   1. mocked unit suite      (breadth + core logic)
#   2. web-server clean lane  (real FastAPI, --noconftest)
#   3. live engine clean lane (real GGUF model, --noconftest)
# See scripts/coverage_full.sh and docs/COVERAGE.md.
# NOTE: coverage's parser does NOT strip inline comments after a value — keep
# comments on their own lines.
#
# The `omit` list excludes ONLY code that genuinely cannot run in headless CI —
# the interactive desktop GUI and hardware I/O (mic/camera/speakers/GPU-vision/
# gaze/OS-control/screen). This measures the *testable surface*. Code that is
# merely untested (e.g. image_engine, the analyze_* parsers, executor handlers)
# is deliberately KEPT in the denominator — excluding it would inflate the number
# dishonestly. Every exclusion here is justified in docs/COVERAGE.md.

[run]
parallel = True
source = eli,api
branch = False
omit =
    */tests/*
    */__pycache__/*
    */build/*
    */.venv/*
    */__main__.py
    */gui/*

[report]
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @(abc\.)?abstractmethod

[html]
directory = artifacts/coverage_html
